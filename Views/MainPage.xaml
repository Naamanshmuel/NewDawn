<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:NewDawn.ViewModels"
             x:Class="NewDawn.Views.MainPage"
             x:DataType="viewmodels:MainViewModel"
             Title="ALS Communication">

    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,0"
            VerticalOptions="Center">

            <Label 
                Text="NewDawn ALS Communication System"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1"
                FontSize="32"
                HorizontalOptions="Center" />

            <Label 
                Text="Helping ALS users communicate effectively"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                FontSize="18"
                HorizontalOptions="Center"
                Margin="0,0,0,20" />

            <!-- Status Section -->
            <Border 
                Padding="20"
                BackgroundColor="{StaticResource Primary}"
                Margin="0,10,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Label 
                    Text="{Binding StatusMessage}"
                    FontSize="16"
                    TextColor="White"
                    HorizontalOptions="Center" />
            </Border>

            <!-- Conversation Controls -->
            <Border 
                Padding="20"
                Margin="0,10,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">
                    <Label 
                        Text="Conversation Controls"
                        FontSize="20"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />

                    <Button 
                        Text="Start Conversation"
                        Command="{Binding StartConversationCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        FontSize="18"
                        HeightRequest="60"
                        CornerRadius="10" />

                    <Button 
                        Text="Stop Conversation"
                        Command="{Binding StopConversationCommand}"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="White"
                        FontSize="18"
                        HeightRequest="60"
                        CornerRadius="10" />
                </VerticalStackLayout>
            </Border>

            <!-- Speech Recognition Controls -->
            <Border 
                Padding="20"
                Margin="0,10,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">
                    <Label 
                        Text="Speech Recognition"
                        FontSize="20"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />

                    <Button 
                        Text="Start Listening"
                        Command="{Binding StartListeningCommand}"
                        BackgroundColor="{StaticResource Success}"
                        TextColor="White"
                        FontSize="18"
                        HeightRequest="60"
                        CornerRadius="10" />

                    <Button 
                        Text="Stop Listening"
                        Command="{Binding StopListeningCommand}"
                        BackgroundColor="{StaticResource Warning}"
                        TextColor="White"
                        FontSize="18"
                        HeightRequest="60"
                        CornerRadius="10" />

                    <!-- Transcribed Text Display -->
                    <Border 
                        Padding="15"
                        BackgroundColor="{StaticResource Gray100}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="5"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">
                            <Label 
                                Text="Transcribed Text:"
                                FontSize="14"
                                FontAttributes="Bold" />
                            <Label 
                                Text="{Binding TranscribedText}"
                                FontSize="16"
                                MinimumHeightRequest="40" />
                        </VerticalStackLayout>
                    </Border>

                    <Button 
                        Text="Process Speech & Generate Responses"
                        Command="{Binding ProcessSpeechCommand}"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="White"
                        FontSize="18"
                        HeightRequest="60"
                        CornerRadius="10" />
                </VerticalStackLayout>
            </Border>

            <!-- Messages Display -->
            <Border 
                Padding="20"
                Margin="0,10,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label 
                        Text="Conversation History"
                        FontSize="20"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />

                    <CollectionView 
                        ItemsSource="{Binding Messages}"
                        MinimumHeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border 
                                    Padding="10"
                                    Margin="0,5,0,5"
                                    BackgroundColor="{StaticResource Gray100}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="5"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="5">
                                        <Label 
                                            Text="{Binding Sender}"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource Primary}" />
                                        <Label 
                                            Text="{Binding Text}"
                                            FontSize="14" />
                                        <Label 
                                            Text="{Binding Timestamp, StringFormat='{0:HH:mm:ss}'}"
                                            FontSize="10"
                                            TextColor="{StaticResource Gray600}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
